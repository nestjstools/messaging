{
  "name": "@nestjstools/messaging-nats-extension",
  "version": "2.1.0",
  "description": "Extension to handle messages and dispatch them over Nats",
  "author": "Sebastian Iwanczyszyn",
  "license": "MIT",
  "main": "lib/index.js",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/nestjstools/messaging/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nestjstools/messaging",
    "directory": "packages/messaging-nats-extension"
  },
  "keywords": [
    "nestjs-tools",
    "nestjs",
    "distributed",
    "messaging",
    "nestjs-messaging",
    "message-bus",
    "service-bus",
    "microservices",
    "nats",
    "nats-messages",
    "nestjs-messaging-nats"
  ],
  "files": [
    "lib",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "nest build",
    "prettier:fix": "prettier --write \"src/**/*.ts\"",
    "prettier": "prettier --check \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/index",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "ci": "yarn prettier",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "nats": "^2.29.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.x||^11.x",
    "@nestjs/core": "^10.x||^11.x",
    "@nestjstools/messaging": "^4.x",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.x"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjstools/messaging": "4.0.0",
    "@semantic-release/github": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semantic-release": "^24.2.3",
    "semantic-release-pr-analyzer": "^1.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "webpack": "^5.105.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "homepage": "https://docs.nestjstools.com/messaging"
}
