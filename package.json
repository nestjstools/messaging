{
  "name": "nestjstools",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:messaging-amazon-sqs-extension": "yarn workspace @nestjstools/messaging-amazon-sqs-extension build",
    "build:messaging-azure-service-bus-extension": "yarn workspace @nestjstools/messaging-azure-service-bus-extension build",
    "build:messaging": "yarn workspace @nestjstools/messaging build",
    "build:messaging-google-pubsub-extension": "yarn workspace @nestjstools/messaging-google-pubsub-extension build",
    "build:messaging-nats-extension": "yarn workspace @nestjstools/messaging-nats-extension build",
    "build:messaging-rabbitmq-extension": "yarn workspace @nestjstools/messaging-rabbitmq-extension build",
    "build:messaging-redis-extension": "yarn workspace @nestjstools/messaging-redis-extension build",
    "test": "npm run test --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nestjstools/messaging.git"
  },
  "homepage": "https://github.com/nestjstools/messaging#readme",
  "bugs": {
    "url": "https://github.com/nestjstools/messaging/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@nestjstools/messaging": "^4.0.1"
  }
}
